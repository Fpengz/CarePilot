# Optional override file for web-only development.
# Default source of truth is root `.env`; only add keys here when you need
# web-specific values that should override root values.

# Use same-origin proxy by default (`/backend/*` -> API server).
NEXT_PUBLIC_API_BASE_URL=/backend
# Provider value submitted by meals UI (`provider` form field).
NEXT_PUBLIC_MEAL_ANALYZE_PROVIDER=ollama
# Upstream API target for Next proxy route:
BACKEND_API_BASE_URL=http://127.0.0.1:8001
# Comma-separated origins allowed to load /_next/* during `next dev`.
# Add your LAN host here when testing from another device.
NEXT_ALLOWED_DEV_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.68.127:3000
# Frontend dev API logging toggles (browser console):
NEXT_PUBLIC_DEV_LOG_FRONTEND=1
NEXT_PUBLIC_DEV_LOG_FRONTEND_VERBOSE=0
