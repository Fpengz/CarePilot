{
  "extends": ["next/core-web-vitals"],
  "ignorePatterns": [
    ".next/",
    "node_modules/",
    "public/",
    "out/",
    "build/",
    "next-env.d.ts"
  ],
  "overrides": [
    {
      "files": ["**/*.{js,jsx,ts,tsx}"],
      "excludedFiles": ["lib/api.ts", "lib/api/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@/lib/api",
                "message": "Use domain clients under @/lib/api/* instead of the legacy consolidated client."
              }
            ]
          }
        ]
      }
    }
  ]
}
