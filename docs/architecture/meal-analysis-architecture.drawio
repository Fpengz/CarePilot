<mxfile host="app.diagrams.net" modified="2026-03-11T07:22:47Z" agent="Copilot" version="24.7.17">
  <diagram id="meal-analysis-arch" name="Meal Analysis Architecture">
    <!--
      Layout rules
      ============
      • Page 1600 × 950
      • 5 tiers (x=60, w=1480).  30 px gaps between tiers so edge routing
        legs land in clear white space and never touch tier-label text.
      • Tier labels: bottom-left corner → clear of all incoming arrows.
      • T4 stores: plain rectangles (no database shape that clips labels).
      • All edge routing legs that cross tier boundaries use explicit
        waypoints placed in the mid-point of the 30 px inter-tier gap.
      • "User Profile" label removed; "Validated Meal Event" label placed
        in the 213 px gap between recon and nrs at the same y-level.
      • Feedback loop routes along the far-right margin (x=1450), which is
        well clear of all tier labels and node text.
    -->
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10"
      guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1"
      pageScale="1" pageWidth="1600" pageHeight="950"
      math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ─────────────────────────────────────────────
             TITLE
        ───────────────────────────────────────────── -->
