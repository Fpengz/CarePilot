# Core provider selection
LLM_PROVIDER=gemini

# Gemini / Google
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional for OpenAI-compatible gateways/proxies.
OPENAI_BASE_URL=
OPENAI_REQUEST_TIMEOUT_SECONDS=120
OPENAI_TRANSPORT_MAX_RETRIES=2

# Local model runtime
OLLAMA_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_MODEL=qwen3-vl:4b
LOCAL_LLM_REQUEST_TIMEOUT_SECONDS=1200
LOCAL_LLM_TRANSPORT_MAX_RETRIES=0

# Logging
DIETARY_GUARDIAN_LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Singapore

# API / Auth (FastAPI)
API_HOST=127.0.0.1
API_PORT=8001
API_CORS_ORIGINS=http://localhost:3000
SESSION_SECRET=change-me
COOKIE_SECURE=false
AUTH_PASSWORD_HASH_SCHEME=pbkdf2_sha256
API_SQLITE_DB_PATH=dietary_guardian_api.db
AUTH_STORE_BACKEND=sqlite
AUTH_SQLITE_DB_PATH=dietary_guardian_auth.db
WORKFLOW_TRACE_PERSISTENCE_ENABLED=false
# Optional web-only override file: apps/web/.env (if present, overrides these for web commands)
NEXT_PUBLIC_API_BASE_URL=/backend
NEXT_PUBLIC_MEAL_ANALYZE_PROVIDER=gemini
BACKEND_API_BASE_URL=http://127.0.0.1:8001

# Image preprocessing (development performance)
IMAGE_DOWNSCALE_ENABLED=false
IMAGE_MAX_SIDE_PX=1024

# Notification channels
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DEV_MODE=1
TELEGRAM_REQUEST_TIMEOUT_SECONDS=10
EMAIL_DEV_MODE=1
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=1
EMAIL_FROM_ADDRESS=noreply@dietary-guardian.local
SMS_DEV_MODE=1
SMS_WEBHOOK_URL=
SMS_API_KEY=
SMS_SENDER_ID=DietaryGuardian
REMINDER_SCHEDULER_INTERVAL_SECONDS=30
REMINDER_SCHEDULER_BATCH_SIZE=100
