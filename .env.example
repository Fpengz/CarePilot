# =============================================================================
# Environment source of truth
# - This root `.env` is loaded by API and web commands.
# - Optional override: `apps/web/.env` (web-only, loaded after this file).
# =============================================================================

# =============================================================================
# Core provider selection
# =============================================================================
LLM_PROVIDER=test
# Optional per-capability routing override (JSON string).
# Note: medication parsing currently uses the base LLM_PROVIDER.
LLM_CAPABILITY_TARGETS={}

# =============================================================================
# Gemini / Google
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# =============================================================================
# OpenAI
# =============================================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional for OpenAI-compatible gateways/proxies.
OPENAI_BASE_URL=
OPENAI_REQUEST_TIMEOUT_SECONDS=120
OPENAI_TRANSPORT_MAX_RETRIES=2

# =============================================================================
# Qwen (OpenAI-compatible)
# =============================================================================
QWEN_API_KEY=
QWEN_MODEL=qwen-vl-cheapest
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# =============================================================================
# SEA-LION / chat runtime
# =============================================================================
SEALION_API=
SEALION_BASE_URL=https://api.sea-lion.ai/v1
CHAT_MODEL_ID=aisingapore/Gemma-SEA-LION-v4-27B-IT
REASONING_MODEL_ID=aisingapore/Llama-SEA-LION-v3.5-70B-R
CHAT_STREAM_MAX_RETRIES=2
CHAT_STREAM_BACKOFF_SECONDS=0.5

# =============================================================================
# Local model runtime
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_MODEL=qwen3-vl:4b
LOCAL_LLM_REQUEST_TIMEOUT_SECONDS=1200
LOCAL_LLM_TRANSPORT_MAX_RETRIES=0

# =============================================================================
# Logging
# =============================================================================
DIETARY_GUARDIAN_LOG_LEVEL=DEBUG
APP_TIMEZONE=Asia/Singapore

# =============================================================================
# Emotion inference
# =============================================================================
EMOTION_INFERENCE_ENABLED=false
EMOTION_SPEECH_ENABLED=false
EMOTION_REQUEST_TIMEOUT_SECONDS=15
EMOTION_MODEL_DEVICE=auto
EMOTION_TEXT_MODEL_ID=j-hartmann/emotion-english-distilroberta-base
EMOTION_SPEECH_MODEL_ID=meralion/speech-emotion-recognition

# =============================================================================
# Mem0 memory layer (chat personalization)
# =============================================================================
MEM0_API_KEY=
MEM0_BASE_URL=
MEM0_ENABLED=false
MEM0_TOP_K=5

# =============================================================================
# API / Auth (FastAPI)
# =============================================================================
API_HOST=127.0.0.1
API_PORT=8001
API_CORS_ORIGINS=http://localhost:3000
SESSION_SECRET=change-me
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
AUTH_PASSWORD_HASH_SCHEME=pbkdf2_sha256
API_SQLITE_DB_PATH=dietary_guardian_api.db
APP_ENV=dev
AUTH_SEED_DEMO_USERS=true
APP_DATA_BACKEND=sqlite
AUTH_STORE_BACKEND=sqlite
AUTH_SQLITE_DB_PATH=dietary_guardian_auth.db
HOUSEHOLD_STORE_BACKEND=sqlite
POSTGRES_DSN=
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=5
POSTGRES_STATEMENT_TIMEOUT_MS=5000
EPHEMERAL_STATE_BACKEND=in_memory
REDIS_URL=
REDIS_NAMESPACE=dietary_guardian
REDIS_DEFAULT_TTL_SECONDS=300
REDIS_LOCK_TTL_SECONDS=30
REDIS_WORKER_SIGNAL_CHANNEL=workers.ready
REDIS_KEYSPACE_VERSION=v2
# READINESS_FAIL_ON_WARNINGS=false
# REQUIRED_PROVIDER=gemini
WORKER_MODE=in_process
REMINDER_WORKER_POLL_INTERVAL_SECONDS=15
OUTBOX_WORKER_POLL_INTERVAL_SECONDS=5
WORKFLOW_TRACE_PERSISTENCE_ENABLED=false

# =============================================================================
# Chat adjunct services
# =============================================================================
GROQ_API_KEY=
E2B_API_KEY=

# =============================================================================
# Notification channels
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DEV_MODE=1
TELEGRAM_REQUEST_TIMEOUT_SECONDS=10
EMAIL_DEV_MODE=1
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_USE_TLS=1
EMAIL_FROM_ADDRESS=noreply@dietary-guardian.local
SMS_DEV_MODE=1
SMS_WEBHOOK_URL=
SMS_API_KEY=
SMS_SENDER_ID=DietaryGuardian
REMINDER_SCHEDULER_INTERVAL_SECONDS=30
REMINDER_SCHEDULER_BATCH_SIZE=100

# =============================================================================
# Web/API dev routing and origin controls
# =============================================================================
# Keep browser calls same-origin via Next proxy route:
NEXT_PUBLIC_API_BASE_URL=/backend
# Meal analyze provider used by web form submissions:
NEXT_PUBLIC_MEAL_ANALYZE_PROVIDER=test
# Upstream API target for /backend/* proxy:
BACKEND_API_BASE_URL=http://127.0.0.1:8001
# Allow Next dev asset requests from localhost + LAN:
NEXT_ALLOWED_DEV_ORIGINS=http://localhost:3000
# Dev logging controls
API_DEV_LOG_VERBOSE=0
API_DEV_LOG_HEADERS=0
API_DEV_LOG_RESPONSE_HEADERS=0
NEXT_PUBLIC_DEV_LOG_FRONTEND=0
NEXT_PUBLIC_DEV_LOG_FRONTEND_VERBOSE=0

# =============================================================================
# Image preprocessing (development performance)
# =============================================================================
IMAGE_DOWNSCALE_ENABLED=false
IMAGE_MAX_SIDE_PX=1024

# =============================================================================
# OpenRecipe API
# =============================================================================
OPENRECIPE_API_KEY=
